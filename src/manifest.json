{
  "manifest_version": 3,
  "name": "BroRecord",
  "version": "0.1.0",
  "description": "Record a browser tab and save as mp4",
  "permissions": [
    "activeTab",
    "tabs",
    "tabCapture",
    "offscreen",
    "downloads",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
