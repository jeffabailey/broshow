{
  "manifest_version": 3,
  "name": "BroShow",
  "version": "0.1.0",
  "description": "Record a browser tab and save as mp4",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
