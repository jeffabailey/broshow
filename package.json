{
  "name": "broshow",
  "version": "0.2.17",
  "description": "Browser extension that records a browser tab and saves as mp4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "package": "node scripts/package-extensions.mjs",
    "sign": "node scripts/sign-firefox-xpi.mjs",
    "dev:firefox": "node scripts/dev-firefox.mjs",
    "dev:chrome": "node scripts/dev-chrome.mjs",
    "validate": "node scripts/validate-bundles.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "playwright test",
    "test:mutation": "stryker run",
    "start": "npm run build && web-ext run --target chromium --source-dir dist/"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "esbuild": "^0.24.0",
    "playwright": "^1.49.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "web-ext": "^10.0.0"
  },
  "dependencies": {
    "mp4-muxer": "^5.2.0"
  }
}
